# AI provider — use "mock" (no API key required) or "openai"
AI_PROVIDER=mock

# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=

# OpenAI model — gpt-4o-mini is cheap (~€0.0003/analysis) and sufficient
OPENAI_MODEL=gpt-4o-mini

# SQLite database file (created automatically on first run)
DATABASE_URL=sqlite:///./roleradar.db
